<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="006-create-locations-schema" author="Sawaron">
        <createTable tableName="locations">
            <column name="id" type="VARCHAR(100)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="level" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="zone_id" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="biome" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="effect" type="VARCHAR(50)" defaultValue="NONE"/>
        </createTable>


        <createTable tableName="location_connections">
            <column name="from_location_id" type="VARCHAR(100)">
                <constraints nullable="false" foreignKeyName="fk_conn_from_location" referencedTableName="locations" referencedColumnNames="id"/>
            </column>
            <column name="to_location_id" type="VARCHAR(100)">
                <constraints nullable="false" foreignKeyName="fk_conn_to_location" referencedTableName="locations" referencedColumnNames="id"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="location_connections"
                             columnNames="from_location_id, to_location_id"
                             constraintName="uq_from_to_connection"/>


        <createTable tableName="location_fixed_monsters">
            <column name="location_id" type="VARCHAR(100)">
                <constraints nullable="false" foreignKeyName="fk_fixed_monster_location" referencedTableName="locations" referencedColumnNames="id"/>
            </column>
            <column name="monster_template_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="count" type="INTEGER">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

