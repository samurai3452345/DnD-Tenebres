    <changeSet id="016-create-magic-system" author="magic_dev">

        <addColumn tableName="player_items">
            <column name="magic_effect" type="VARCHAR(50)" defaultValue="NONE">
                <constraints nullable="false"/>
            </column>
            <column name="magic_effect_element" type="VARCHAR(50)"/>
        </addColumn>

        <createTable tableName="spells">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="version" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="tier" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="mana_cost" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="element" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="damage_dice" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="dice_count" type="INTEGER" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="flat_bonus" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="effect_type" type="VARCHAR(50)" defaultValue="NONE">
                <constraints nullable="false"/>
            </column>
            <column name="effect_target" type="VARCHAR(50)" defaultValue="NONE">
                <constraints nullable="false"/>
            </column>
            <column name="effect_duration" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="effect_power" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>

