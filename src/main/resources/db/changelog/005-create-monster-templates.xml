    <changeSet id="005-create-monster-templates" author="Sawaron">

        <createTable tableName="monster_templates">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="biome" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="level" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="base_hp" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="armor_class" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="xp_reward" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="gold_reward" type="INTEGER">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="template_elements">
            <column name="template_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_template_elements_template" referencedTableName="monster_templates" referencedColumnNames="id"/>
            </column>
            <column name="element" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
        </createTable>


