<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="005-create-monster-templates" author="Sawaron">

        <createTable tableName="monster_templates">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="biome" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="level" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="base_hp" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="armor_class" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="xp_reward" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="gold_reward" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="damage_dice" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="dice_count" type="INTEGER" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="damage_bonus" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="attack_name" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>

            <!-- НОВЫЕ КОЛОНКИ ДЛЯ СУПЕР-УДАРОВ -->
            <column name="special_skill" type="VARCHAR(50)" defaultValue="NONE">
                <constraints nullable="false"/>
            </column>
            <column name="skill_frequency" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="template_elements">
            <column name="template_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_template_elements_template" referencedTableName="monster_templates" referencedColumnNames="id"/>
            </column>
            <column name="element" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- НОВАЯ ТАБЛИЦА ДЛЯ РЕЗИСТОВ -->
        <createTable tableName="template_resistances">
            <column name="template_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_templ_res_templ" referencedTableName="monster_templates" referencedColumnNames="id"/>
            </column>
            <column name="element" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
        </createTable>

