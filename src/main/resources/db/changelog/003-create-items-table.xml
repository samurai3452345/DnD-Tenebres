<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

    <changeSet id="003-create-items-table" author="Sawaron">
        <createTable tableName="items">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="player_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_items_player" referencedTableName="players" referencedColumnNames="id"/>
            </column>

            <column name="item_type" type="VARCHAR(31)">
                <constraints nullable="false"/>
            </column>

            <column name="rarity" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="current_xp" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

            <column name="base_dice_type" type="VARCHAR(10)"/>
            <column name="is_equipped" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="equip_slot" type="VARCHAR(50)"/>

            <column name="parent_item_id" type="BIGINT">
                <constraints foreignKeyName="fk_items_parent" referencedTableName="items" referencedColumnNames="id"/>
            </column>

            <column name="stat_str" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="stat_dex" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="stat_con" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="stat_int" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="stat_wis" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="stat_cha" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>